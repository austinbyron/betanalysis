# The Odds API Key - get one at https://the-odds-api.com/
ODDS_API_KEY=your_api_key_here

# All other settings come from config.yaml or BETANALYSIS_* env vars
# (viper: section and key joined with _, e.g.):
# BETANALYSIS_DATABASE_HOST=localhost
# BETANALYSIS_DATABASE_PORT=5432
# BETANALYSIS_DATABASE_NAME=betanalysis
# BETANALYSIS_DATABASE_USER=betuser
# BETANALYSIS_DATABASE_PASSWORD=betpass

# Trading
# BETANALYSIS_TRADING_INITIAL_BANKROLL=1000.0
# BETANALYSIS_TRADING_MIN_STAKE=1.0
# BETANALYSIS_TRADING_MAX_STAKE_FRACTION=0.05
# BETANALYSIS_TRADING_KELLY_FRACTION=0.5
# BETANALYSIS_TRADING_MIN_ODDS=1.5
# BETANALYSIS_TRADING_MIN_EXPECTED_VALUE=0.05

# Analysis
# BETANALYSIS_ANALYSIS_MODEL_TYPE=thompson   # thompson | epsilon_greedy | historical
# BETANALYSIS_ANALYSIS_MARKET_WEIGHT=0.7     # weight on de-vigged market probability
